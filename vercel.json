{
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/FootwearMaker/(.*)",
      "destination": "/$1"
    },
    {
      "source": "/FootwearMaker",
      "destination": "/index.html"
    },
    {
      "source": "/FootwearMaker",
      "destination": "/footwearmaker",
      "permanent": true
    }
  ]
}
