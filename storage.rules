rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // Public library models - readable by all authenticated users, writable by admins only
    match /users/public/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // User files
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 50 * 1024 * 1024
        && (request.resource.contentType.matches('application/octet-stream')
            || request.resource.contentType.matches('model/gltf-binary')
            || request.resource.contentType.matches('image/jpeg')
            || request.resource.contentType.matches('image/png')
            || request.resource.contentType.matches('image/gif')
            || request.resource.contentType.matches('image/webp')
            || request.resource.contentType.matches('video/mp4')
            || request.resource.contentType.matches('video/webm')
            || request.resource.contentType.matches('video/quicktime'));
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Video thumbnails - explicitly allow PNG thumbnails in the videos folder
    match /users/{userId}/videos/thumbnails/{thumbnail} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/png');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Thumbnails
    match /thumbnails/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/png');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Videos - added to support the Wan21itv app
    match /videos/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 100 * 1024 * 1024
        && (request.resource.contentType.matches('video/mp4')
            || request.resource.contentType.matches('video/webm')
            || request.resource.contentType.matches('video/quicktime'));
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Temporary files
    match /temp/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Public files - accessible to EVERYONE (no authentication required)
    // This is needed for Aura Automata QR codes and public sculpture sharing
    match /public/{allPaths=**} {
      allow read: if true;  // Public read access for everyone
      allow write: if isAdmin();
    }

    // History folder - explicit rules for generation history
    match /users/{userId}/history/{historyFile} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 100 * 1024 * 1024
        && (request.resource.contentType.matches('image/jpeg')
            || request.resource.contentType.matches('image/png')
            || request.resource.contentType.matches('image/webp')
            || request.resource.contentType.matches('video/mp4')
            || request.resource.contentType.matches('video/webm')
            || request.resource.contentType.matches('video/quicktime')
            || request.resource.contentType.matches('application/octet-stream')
            || request.resource.contentType.matches('model/gltf-binary')
            || request.resource.contentType.matches('text/plain'));
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny all other access
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
